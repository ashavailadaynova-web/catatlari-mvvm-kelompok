<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp"
    android:background="#000000"
    tools:context=".view.AddRunFragment">

    <!-- Watermark Background KINETIC (Biar Rame) -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="KINETIC"
        android:textColor="#0A0A0A"
        android:textSize="100sp"
        android:textStyle="bold"
        android:rotation="-90"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginEnd="-120dp"
        android:layout_marginBottom="100dp" />

    <!-- Tombol Kembali -->
    <ImageButton
        android:id="@+id/btn_back"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Back"
        android:src="@drawable/ic_back"
        app:tint="#D4FF00"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginStart="-12dp" />

    <!-- Judul Section -->
    <TextView
        android:id="@+id/txt_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Let's Share"
        android:textColor="#D4FF00"
        android:textStyle="bold"
        android:textSize="36sp"
        android:letterSpacing="-0.02"
        app:layout_constraintTop_toBottomOf="@id/btn_back"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/txt_title2"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="your journey!"
        android:textColor="#FFFFFF"
        android:textSize="28sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/txt_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Input Tanggal -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/til_date"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:hint="Tanggal Lari"
        android:textColorHint="#666666"
        app:startIconDrawable="@android:drawable/ic_menu_my_calendar"
        app:startIconTint="#D4FF00"
        app:startIconCheckable="false"
        app:boxStrokeColor="@color/text_input_stroke_color"
        app:boxStrokeWidth="2dp"
        app:boxStrokeWidthFocused="3dp"
        app:hintTextColor="#D4FF00"
        app:layout_constraintTop_toBottomOf="@id/txt_title2">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_date"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:drawablePadding="16dp"
            android:paddingStart="45dp"
            android:inputType="none"
            android:focusable="false"
            android:clickable="true" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Input Jarak -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/til_distance"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:hint="Jarak Lari (KM)"
        android:textColorHint="#666666"
        app:startIconDrawable="@android:drawable/ic_menu_directions"
        app:startIconTint="#D4FF00"
        app:startIconCheckable="false"
        app:boxStrokeColor="@color/text_input_stroke_color"
        app:boxStrokeWidth="2dp"
        app:boxStrokeWidthFocused="3dp"
        app:hintTextColor="#D4FF00"
        app:layout_constraintTop_toBottomOf="@id/til_date">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_run_distance"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:drawablePadding="16dp"
            android:paddingStart="45dp"
            android:inputType="numberDecimal" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Input Durasi -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/til_duration"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:hint="Durasi (hh:mm:ss)"
        android:textColorHint="#666666"
        app:startIconDrawable="@android:drawable/ic_menu_recent_history"
        app:startIconTint="#D4FF00"
        app:startIconCheckable="false"
        app:boxStrokeColor="@color/text_input_stroke_color"
        app:boxStrokeWidth="2dp"
        app:boxStrokeWidthFocused="3dp"
        app:hintTextColor="#D4FF00"
        app:layout_constraintTop_toBottomOf="@id/til_distance">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_run_duration"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:drawablePadding="16dp"
            android:paddingStart="45dp"
            android:inputType="time" />
    </com.google.android.material.textfield.TextInputLayout>
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="PASTIKAN DATA SUDAH SESUAI"
        android:textColor="#333333"
        android:textSize="10sp"
        android:letterSpacing="0.2"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/til_duration"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Tombol Simpan -->
    <Button
        android:id="@+id/btn_save_run"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginBottom="16dp"
        android:text="CATAT LARI"
        android:textColor="#000000"
        android:textSize="16sp"
        android:textStyle="bold"
        android:backgroundTint="#D4FF00"
        android:letterSpacing="0.1"
        app:cornerRadius="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />


</androidx.constraintlayout.widget.ConstraintLayout>