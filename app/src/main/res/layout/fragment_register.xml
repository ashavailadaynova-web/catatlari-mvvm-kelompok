<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black"
    android:padding="24dp"
    tools:context=".view.RegisterFragment">

    <!-- Title: Create Account -->
    <TextView
        android:id="@+id/txt_register_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="60dp"
        android:fontFamily="@font/lexend_black"
        android:text="Create Account"
        android:textColor="@color/white"
        android:textSize="28sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/txt_register_subtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:fontFamily="@font/lexend_regular"
        android:letterSpacing="0.1"
        android:text="Join us to start tracking your runs and share your journey!"
        android:textColor="#888888"
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/txt_register_title" />

    <!-- Input Nama -->
    <EditText
        android:id="@+id/et_name_signup"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginTop="32dp"
        android:background="@drawable/bg_input_stroke"
        android:drawableStart="@drawable/ic_person"
        android:drawablePadding="12dp"
        android:fontFamily="@font/lexend_regular"
        android:hint="Full Name"
        android:inputType="textPersonName"
        android:paddingHorizontal="20dp"
        android:textColor="@color/white"
        android:textColorHint="#555555"
        app:layout_constraintTop_toBottomOf="@id/txt_register_subtitle" />

    <!-- Input Email -->
    <EditText
        android:id="@+id/et_email_signup"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_input_stroke"
        android:drawableStart="@drawable/ic_email"
        android:drawablePadding="12dp"
        android:fontFamily="@font/lexend_regular"
        android:hint="Email Address"
        android:inputType="textEmailAddress"
        android:paddingHorizontal="20dp"
        android:textColor="@color/white"
        android:textColorHint="#555555"
        app:layout_constraintTop_toBottomOf="@id/et_name_signup" />

    <!-- Input Password -->
    <EditText
        android:id="@+id/et_password_signup"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_input_stroke"
        android:drawableStart="@drawable/ic_password"
        android:drawablePadding="12dp"
        android:fontFamily="@font/lexend_regular"
        android:hint="Password"
        android:inputType="textPassword"
        android:paddingHorizontal="20dp"
        android:textColor="@color/white"
        android:textColorHint="#555555"
        app:layout_constraintTop_toBottomOf="@id/et_email_signup" />

    <!-- Input Retype Password -->
    <EditText
        android:id="@+id/et_retype_password_signup"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_input_stroke"
        android:drawableStart="@drawable/ic_password"
        android:drawablePadding="12dp"
        android:fontFamily="@font/lexend_regular"
        android:hint="Confirm Password"
        android:inputType="textPassword"
        android:paddingHorizontal="20dp"
        android:textColor="@color/white"
        android:textColorHint="#555555"
        app:layout_constraintTop_toBottomOf="@id/et_password_signup" />

    <!-- Tombol Register -->
    <Button
        android:id="@+id/btn_register_action"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginTop="32dp"
        android:backgroundTint="@color/neon_green"
        android:fontFamily="@font/lexend_medium"
        android:text="CREATE ACCOUNT"
        android:textAllCaps="true"
        android:textColor="@color/black"
        android:textSize="16sp"
        app:cornerRadius="12dp"
        app:layout_constraintTop_toBottomOf="@id/et_retype_password_signup" />

    <!-- Footer: Back to Login -->
    <LinearLayout
        android:id="@+id/layout_signin_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="32dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/lexend_regular"
            android:letterSpacing="0.05"
            android:text="ALREADY A MEMBER?"
            android:textColor="#B7B5B4"
            android:textSize="13sp" />

        <Button
            android:id="@+id/btn_go_to_login"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/lexend_medium"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:paddingStart="4dp"
            android:paddingEnd="8dp"
            android:text="LOG IN"
            android:textColor="@color/neon_green"
            android:textSize="13sp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>