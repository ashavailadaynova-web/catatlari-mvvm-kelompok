<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black"
    android:padding="24dp"
    tools:context=".view.LoginFragment">

    <!-- Greeting dengan Nama Panjang -->
    <TextView
        android:id="@+id/txt_hello_world"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="60dp"
        android:text="Welcome Back!"
        android:textColor="@color/white"
        android:textSize="28sp"
        android:textStyle="bold"
        android:fontFamily="@font/lexend_black"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Deskripsi Asli -->
    <TextView
        android:id="@+id/txt_kelas_pemrograman"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="We missed you! Login to continue to share your experience with us!"
        android:textColor="#888888"
        android:textSize="14sp"
        android:letterSpacing="0.1"
        android:fontFamily="@font/lexend_regular"
        app:layout_constraintTop_toBottomOf="@id/txt_hello_world"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Input Email dengan Style Stroke -->
    <EditText
        android:id="@+id/et_email"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginTop="40dp"
        android:background="@drawable/bg_input_stroke"
        android:drawableStart="@drawable/ic_email"
        android:drawablePadding="12dp"
        android:hint="Your Email"
        android:paddingHorizontal="20dp"
        android:textColor="@color/white"
        android:textColorHint="#555555"
        android:inputType="textEmailAddress"
        app:layout_constraintTop_toBottomOf="@id/txt_kelas_pemrograman" />

    <!-- Input Password dengan Style Stroke -->
    <EditText
        android:id="@+id/et_password"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_input_stroke"
        android:drawableStart="@drawable/ic_password"
        android:drawablePadding="12dp"
        android:hint="Your Password"
        android:paddingHorizontal="20dp"
        android:textColor="@color/white"
        android:textColorHint="#555555"
        android:inputType="textPassword"
        app:layout_constraintTop_toBottomOf="@id/et_email" />

    <!-- Tombol Login Hijau Neon -->
    <Button
        android:id="@+id/btn_go_to_home"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginTop="32dp"
        android:backgroundTint="@color/neon_green"
        android:text="LOG IN"
        android:textColor="@color/black"
        android:textStyle="bold"
        android:textAllCaps="false"
        android:textSize="16sp"
        app:cornerRadius="12dp"
        app:layout_constraintTop_toBottomOf="@id/et_password" />


    <LinearLayout
        android:id="@+id/layout_signin_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="208dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/lexend_regular"
            android:letterSpacing="0.05"
            android:text="DON'T HAVE AN ACCOUNT YET?"
            android:textColor="#B7B5B4"
            android:textSize="13sp" />

        <!-- Menggunakan TextButton agar ada efek ripple saat ditekan -->
        <Button
            android:id="@+id/btn_go_to_register"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/lexend_medium"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:paddingStart="4dp"
            android:paddingEnd="8dp"
            android:text="SIGN UP"
            android:textAllCaps="true"
            android:textColor="@color/neon_green"
            android:textSize="13sp"
            android:textStyle="bold" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>